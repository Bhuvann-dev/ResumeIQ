# Copy to .env and fill in. Never commit the real .env.

# --- Option A: OpenAI (for the deployed/public demo) ---
# Your OpenAI API key — https://platform.openai.com/api-keys
# (This is the pay-as-you-go API, separate from a ChatGPT subscription.)
OPENAI_API_KEY=sk-...
OPENAI_MODEL=gpt-4o-2024-08-06

# --- Option B: Ollama (free local dev — no key needed) ---
# Install Ollama, run `ollama pull llama3.1`, then uncomment these two lines.
# The app talks to Ollama through its OpenAI-compatible endpoint, so no code
# changes are needed. OPENAI_API_KEY can be left blank when using Ollama.
# OPENAI_BASE_URL=http://localhost:11434/v1
# OPENAI_MODEL=llama3.1

# Comma-separated allowed frontend origins, or * for local dev.
CORS_ORIGINS=*
