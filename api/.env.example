# Copy to .env and fill in. Never commit the real .env.

# Your OpenAI API key — get one at https://platform.openai.com/api-keys
# (Note: this is the pay-as-you-go API, separate from a ChatGPT subscription.)
OPENAI_API_KEY=sk-...

# Model to use. gpt-4o-2024-08-06 supports Structured Outputs.
OPENAI_MODEL=gpt-4o-2024-08-06

# Comma-separated allowed frontend origins, or * for local dev.
# e.g. https://resume-iq.vercel.app
CORS_ORIGINS=*
